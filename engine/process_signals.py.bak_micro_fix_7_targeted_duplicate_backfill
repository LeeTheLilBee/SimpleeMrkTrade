                    "vehicle_selected": fused.get("vehicle_selected"),
                    "option_fallback_used": fused.get("option_fallback_used"),
                    "capital_required": fused.get("capital_required"),
                    "minimum_trade_cost": fused.get("minimum_trade_cost"),
