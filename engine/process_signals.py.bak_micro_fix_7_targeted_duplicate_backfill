    selected_trades = finalized_selected_trades

    print("\nAPPROVAL DEBUG")
    # ------------------------------------------------------------
    # Backfill selected queue after strict anti-repeat filtering
    # ------------------------------------------------------------
    try:
        strict_blocked_symbols_for_backfill = []

        try:
            # ------------------------------------------------------------
            # STRICT ANTI-REPEAT BACKFILL
            # If anti-repeat blocks the selected row, do NOT re-add it.
            # Backfill from the next clean execution-ready candidate instead.
            # ------------------------------------------------------------

            blocked_symbols = set()
            blocked_reasons = []

            # Pull blocked symbols from common guard variable names.
            for _guard_name in [
                "anti_repeat_selection_guard",
                "anti_repeat_guard",
                "anti_repeat_summary",
                "anti_repeat_result",
                "selection_guard",
            ]:
                _guard = locals().get(_guard_name)

                if isinstance(_guard, dict):
                    for _sym in (_guard.get("blocked_symbols") or []):
                        if _sym:
                            blocked_symbols.add(str(_sym).strip().upper())

                    for _reason in (_guard.get("blocked_reasons") or []):
                        if _reason:
                            blocked_reasons.append(str(_reason))

                    for _row in (_guard.get("blocked") or _guard.get("blocked_rows") or []):
                        if isinstance(_row, dict) and _row.get("symbol"):
                            blocked_symbols.add(str(_row.get("symbol")).strip().upper())

            # Use selected_for_execution if it exists.
            if "selected_for_execution" not in locals() or not isinstance(selected_for_execution, list):
                selected_for_execution = []

            # Detect blocked symbols from selected rows too.
            _hard_block_reasons = {
                "setup_fatigue_detected",
                "recent_close_requires_fresh_catalyst",
                "symbol_cooldown_active",
                "recently_rejected",
                "recently_closed",
                "anti_repeat_blocked",
            }

            for _row in list(selected_for_execution):
                if not isinstance(_row, dict):
                    continue

                _sym = str(_row.get("symbol") or "").strip().upper()
                _reason = str(
                    _row.get("anti_repeat_reason")
                    or _row.get("blocked_reason")
                    or _row.get("selector_reason")
                    or _row.get("final_reason")
                    or ""
                ).strip()

                if _sym and _reason in _hard_block_reasons:
                    blocked_symbols.add(_sym)
                    blocked_reasons.append(_reason)

            # Find the richest candidate/debug pool available.
            _debug_pool = []
            for _pool_name in [
                "candidate_debug_rows",
                "debug_rows",
                "approval_debug_rows",
                "all_candidate_rows",
                "approved_candidates",
                "execution_ready_candidates",
            ]:
                _pool = locals().get(_pool_name)
                if isinstance(_pool, list) and _pool:
                    _debug_pool = _pool
                    break

            # Detect blocked symbols from debug pool.
            for _row in _debug_pool:
                if not isinstance(_row, dict):
                    continue

                _sym = str(_row.get("symbol") or "").strip().upper()
                _reason = str(_row.get("final_reason") or "").strip()
                _blocked_at = str(_row.get("blocked_at") or "").strip()

                if _sym and (_reason in _hard_block_reasons or _blocked_at == "anti_repeat_guard"):
                    blocked_symbols.add(_sym)
                    blocked_reasons.append(_reason or _blocked_at)

            # Remove blocked symbols from selected queue.
            _clean_selected = []
            for _row in selected_for_execution:
                if not isinstance(_row, dict):
                    continue

                _sym = str(_row.get("symbol") or "").strip().upper()

                if _sym and _sym in blocked_symbols:
                    _row["selected_for_execution"] = False
                    _row["execution_ready"] = False
                    _row["blocked_at"] = "anti_repeat_guard"
                    _row["final_reason"] = _row.get("anti_repeat_reason") or "setup_fatigue_detected"
                    _row["final_reason_detail"] = _row.get("final_reason_detail") or f"{_sym} was blocked by strict anti-repeat."
                    continue

                _clean_selected.append(_row)

            selected_for_execution = _clean_selected

            # Determine target selection size without touching undefined queue_limit.
            _target_limit = 0
            for _limit_name in ["selection_limit", "effective_limit", "remaining_position_slots"]:
                try:
                    _value = locals().get(_limit_name)
                    if _value is not None:
                        _target_limit = int(_value)
                        break
                except Exception:
                    pass

            _needed = max(0, _target_limit - len(selected_for_execution))

            # Backfill from clean execution-ready candidates.
            _backfilled = []
            _selected_symbols = {
                str(_row.get("symbol") or "").strip().upper()
                for _row in selected_for_execution
                if isinstance(_row, dict) and _row.get("symbol")
            }

            if _needed > 0:
                _backfill_pool = []
                for _pool_name in [
                    "execution_ready_candidates",
                    "approved_candidates",
                    "candidate_debug_rows",
                    "debug_rows",
                    "approval_debug_rows",
                    "all_candidate_rows",
                ]:
                    _pool = locals().get(_pool_name)
                    if isinstance(_pool, list) and _pool:
                        _backfill_pool = _pool
                        break

                _clean_pool = []

                for _row in _backfill_pool:
                    if not isinstance(_row, dict):
                        continue

                    _sym = str(_row.get("symbol") or "").strip().upper()
                    if not _sym:
                        continue

                    if _sym in blocked_symbols:
                        continue

                    if _sym in _selected_symbols:
                        continue

                    if _row.get("duplicate_open_found") is True:
                        continue

                    if _row.get("research_approved") is not True:
                        continue

                    if _row.get("execution_ready") is not True:
                        continue

                    if _row.get("execution_guard_blocked") is True:
                        continue

                    if str(_row.get("blocked_at") or "").strip():
                        continue

                    _reason = str(_row.get("final_reason") or "").strip()
                    if _reason in {
                        "already_open_position",
                        "setup_fatigue_detected",
                        "recent_close_requires_fresh_catalyst",
                        "symbol_cooldown_active",
                        "recently_rejected",
                        "recently_closed",
                        "anti_repeat_blocked",
                    }:
                        continue

                    _clean_pool.append(_row)

                try:
                    _clean_pool = sorted(
                        _clean_pool,
                        key=lambda _r: float(_r.get("score") or 0),
                        reverse=True,
                    )
                except Exception:
                    pass

                for _row in _clean_pool[:_needed]:
                    _patched = dict(_row)
                    _patched["selected_for_execution"] = True
                    _patched["final_reason"] = "selected_for_execution"
                    _patched["final_reason_detail"] = "Candidate was backfilled after strict anti-repeat removed a blocked setup."
                    _patched["blocked_at"] = ""

                    selected_for_execution.append(_patched)
                    _backfilled.append(_patched)

                    _sym = str(_patched.get("symbol") or "").strip().upper()
                    if _sym:
                        _selected_symbols.add(_sym)

            # Sync visible/debug rows.
            _final_selected_symbols = {
                str(_row.get("symbol") or "").strip().upper()
                for _row in selected_for_execution
                if isinstance(_row, dict) and _row.get("symbol")
            }

            for _row in _debug_pool:
                if not isinstance(_row, dict):
                    continue

                _sym = str(_row.get("symbol") or "").strip().upper()

                if _sym in blocked_symbols:
                    _row["selected_for_execution"] = False
                    _row["execution_ready"] = False
                    _row["blocked_at"] = "anti_repeat_guard"
                    if not _row.get("final_reason"):
                        _row["final_reason"] = "setup_fatigue_detected"

                elif _sym in _final_selected_symbols:
                    _row["selected_for_execution"] = True
                    _row["final_reason"] = "selected_for_execution"
                    _row["blocked_at"] = ""

                elif _row.get("research_approved") is True and _row.get("execution_ready") is True:
                    _row["selected_for_execution"] = False
                    if str(_row.get("final_reason") or "").strip() in {"", "execution_ready", "selected_for_execution"}:
                        _row["final_reason"] = "approved_but_ranked_below_execution_cut"

            print(
                "PROCESS SIGNALS STRICT ANTI-REPEAT BACKFILL:",
                {
                    "backfilled_count": len(_backfilled),
                    "backfilled_symbols": [
                        _row.get("symbol") for _row in _backfilled if isinstance(_row, dict)
                    ],
                    "blocked_symbols_respected": sorted(list(blocked_symbols)),
                    "blocked_reasons": blocked_reasons[:10],
                    "selected_symbols_after_backfill": [
                        _row.get("symbol") for _row in selected_for_execution if isinstance(_row, dict)
                    ],
                    "reason": (
                        "backfilled"
                        if _backfilled
                        else "selection_already_full"
                        if len(selected_for_execution) >= _target_limit
                        else "no_clean_backfill_candidates"
                    ),
                },
            )

        except Exception as e:
            print("PROCESS SIGNALS STRICT ANTI-REPEAT BACKFILL ERROR:", str(e))
            selected_trades = selected_trades if selected_trades is not None else []
        if selected_trades is None:
            selected_trades = []

        if execution_ready is None:
            execution_ready = []

        backfill_payload = _backfill_selected_after_strict_antirepeat_filter(
            selected_trades=selected_trades,
            execution_ready=execution_ready,
            blocked_symbols=strict_blocked_symbols_for_backfill,
            capacity=capacity,
            current_open_positions=current_open_positions_for_guard,
            max_open_positions=max_open_positions_for_guard,
            queue_limit=_safe_int(capacity.get("selection_limit", capacity.get("queue_limit", 0)), 0),
        )

        selected_trades = backfill_payload.get("selected_trades", selected_trades)
        backfilled = backfill_payload.get("backfilled", [])
        backfilled_symbols = backfill_payload.get("backfilled_symbols", [])

        print("PROCESS SIGNALS STRICT ANTI-REPEAT BACKFILL:", {
            "backfilled_count": len(backfilled),
            "backfilled_symbols": backfilled_symbols,
            "blocked_symbols_respected": strict_blocked_symbols_for_backfill,
            "selected_symbols_after_backfill": [
                str(x.get("symbol", "") or "").strip().upper()
                for x in selected_trades
                if isinstance(x, dict)
            ],
            "reason": backfill_payload.get("reason", ""),
        })

    except Exception as backfill_error:
        print("PROCESS SIGNALS STRICT ANTI-REPEAT BACKFILL ERROR:", str(backfill_error))

    for row in debug_rows:
        print(row)

    final_execution_reason = governor_reason if governor_reason else (
        ""
        if capacity.get("capacity_reason") in {"selection_capacity_available", "capacity_available"}
        else capacity.get("capacity_reason", "")
    )

    final_execution_pause = _human_execution_pause(
        reason=final_execution_reason,
        governor=governor,
        capacity=capacity,
    )

    final_execution_pause = _apply_anti_repeat_status_overlay(
        final_execution_pause=final_execution_pause,
        anti_repeat_selection_guard=anti_repeat_selection_guard,
        selected_trades=selected_trades,
    )

    print("PROCESS SIGNALS FINAL SELECTION SUMMARY:", {
        "research_approved_count": len(research_approved),
        "execution_ready_count": len([t for t in research_approved if bool(t.get("execution_ready", False))]),
        "selected_count": len(selected_trades),
        "selected_symbols": [_norm_symbol(t.get("symbol")) for t in selected_trades],
        "capacity": capacity,
        "anti_repeat_selection_guard": {
            "input_count": anti_repeat_selection_guard.get("input_count"),
            "allowed_count": anti_repeat_selection_guard.get("allowed_count"),
            "blocked_count": anti_repeat_selection_guard.get("blocked_count"),
            "allowed_symbols": anti_repeat_selection_guard.get("allowed_symbols"),
            "blocked_symbols": anti_repeat_selection_guard.get("blocked_symbols"),
        },
        "execution_pause": final_execution_pause,
    })

    if research_approved:
        print_leaderboard(research_approved)
        print_top_candidates(research_approved, limit=5)
        save_top_candidates(research_approved, limit=10)
    else:
        print("No approved trades.")
        print("TOP CANDIDATES None")

    print("RESEARCH APPROVED CANDIDATE INTELLIGENCE")
    if not research_approved:
        print("None")
    else:
        for trade in research_approved:
            _print_candidate_line(trade)

    print("EXECUTION READY CANDIDATE INTELLIGENCE")
    execution_ready_now = [
        t for t in research_approved
        if bool(t.get("execution_ready", False))
    ]

    if not execution_ready_now:
        print("None")
    else:
        for trade in execution_ready_now:
            _print_candidate_line(trade)

    print("SELECTED FOR EXECUTION CANDIDATE INTELLIGENCE")
    if not selected_trades:
        print("None")
    else:
        for trade in selected_trades:
            _print_candidate_line(trade)

    print("OBSERVATORY EXECUTION STATUS:", {
        "headline": final_execution_pause.get("headline"),
        "summary": final_execution_pause.get("summary"),
        "research_scan_status": "continued",
        "execution_status": "paused" if final_execution_pause.get("paused") else "allowed",
        "reason": final_execution_pause.get("reason", ""),
    })

    return research_approved, selected_trades, mode, breadth, volatility_state


