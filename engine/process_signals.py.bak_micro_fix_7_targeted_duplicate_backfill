                reason="approved_but_ranked_below_execution_cut",
                mode=mode,
                breadth=breadth,
                volatility_state=volatility_state,
                extra={
                    "selector_capacity": capacity,
                    "anti_repeat_selection_guard": anti_repeat_selection_guard,
                },
            )

        else:
            trade["selector_capacity"] = capacity
            trade["anti_repeat_selection_guard"] = anti_repeat_selection_guard
            finalized_research_approved.append(trade)

