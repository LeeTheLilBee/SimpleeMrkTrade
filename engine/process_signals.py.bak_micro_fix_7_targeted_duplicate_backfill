            trade["execution_ready"] = False
            trade["research_approved"] = True
            trade["blocked_at"] = "anti_repeat_guard"
            trade["final_reason"] = reason
            trade["final_reason_code"] = reason
            trade["final_reason_detail"] = detail
            trade["cooldown_reason"] = reason
            trade["cooldown_detail"] = detail
            trade["recent_close_guard"] = blocked_trade.get("recent_close_guard", {})
