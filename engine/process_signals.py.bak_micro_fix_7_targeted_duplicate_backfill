def _closed_position_rows() -> List[Dict[str, Any]]:
    root = _project_root()
    rows: List[Dict[str, Any]] = []

    sources = [
        ("data/closed_positions.json", ["closed_positions", "positions", "trades", "ledger"]),
        ("data/trade_log.json", ["trade_log", "trades", "ledger", "closed_positions"]),
        ("data/trade_activity_events.json", ["events", "activity", "trade_activity_events"]),
    ]

    for rel_path, keys in sources:
        payload = _load_json(root / rel_path, [])
        rows.extend(_json_rows(payload, keys))

    closed: List[Dict[str, Any]] = []

    for row in rows:
        if not isinstance(row, dict):
            continue

        status = _safe_str(
            row.get("status")
            or row.get("position_status")
            or row.get("action"),
            "",
        ).upper()

        close_reason = _safe_str(
            row.get("close_reason")
            or row.get("exit_reason")
            or row.get("reason"),
            "",
        )

        closed_at = _safe_str(
            row.get("closed_at")
            or row.get("exit_time")
            or row.get("exit_timestamp")
            or row.get("closed_timestamp")
            or row.get("timestamp"),
            "",
        )

        if status in {"CLOSED", "CLOSE", "SELL", "EXIT", "EXECUTED_CLOSE"} or close_reason or closed_at:
            closed.append(row)

    return closed


def _closed_at_from_row(row: Dict[str, Any]) -> str:
    return _safe_str(
        row.get("closed_at")
        or row.get("exit_time")
        or row.get("exit_timestamp")
        or row.get("closed_timestamp")
        or row.get("timestamp"),
        "",
    )


def _has_fresh_catalyst(trade: Dict[str, Any]) -> bool:
    trade = _safe_dict(trade)

    for key in [
        "fresh_catalyst",
        "has_fresh_catalyst",
        "new_catalyst",
        "fresh_news",
        "new_news",
        "fresh_breakout",
        "fresh_volume_shift",
        "fresh_options_flow",
    ]:
        value = trade.get(key)

        if isinstance(value, bool) and value:
            return True

        if isinstance(value, str) and value.strip().lower() in {"true", "yes", "y", "1"}:
            return True

    catalyst_text = (
        _safe_str(trade.get("catalyst"), "")
        or _safe_str(trade.get("news_catalyst"), "")
        or _safe_str(trade.get("fresh_catalyst_detail"), "")
    )

    return bool(catalyst_text)


def _recent_close_block_for_trade(
    trade: Dict[str, Any],
    *,
    symbol_cooldown_hours: float = 48.0,
    contract_cooldown_hours: float = 96.0,
) -> Dict[str, Any]:
    trade = _normalize_option_contract_identity(trade)
    symbol = _norm_symbol(trade.get("symbol"))
    contract = _contract_symbol_from_trade(trade)

    if not symbol or symbol == "UNKNOWN":
        return {"blocked": False, "reason": "missing_symbol"}

    if _has_fresh_catalyst(trade):
        return {
            "blocked": False,
            "reason": "fresh_catalyst_present",
            "symbol": symbol,
            "contract": contract,
        }

    newest_symbol_row: Dict[str, Any] = {}
    newest_contract_row: Dict[str, Any] = {}
    newest_symbol_hours = 999999.0
    newest_contract_hours = 999999.0

    for row in _closed_position_rows():
        if not isinstance(row, dict):
            continue

        row_symbol = _norm_symbol(row.get("symbol"))
        if row_symbol != symbol:
            continue

        hours = _hours_since(_closed_at_from_row(row))

        if hours < newest_symbol_hours:
            newest_symbol_hours = hours
            newest_symbol_row = row

        row_contract = _contract_symbol_from_trade(row)
        if contract and row_contract and row_contract == contract and hours < newest_contract_hours:
            newest_contract_hours = hours
            newest_contract_row = row

    if newest_contract_row and newest_contract_hours <= contract_cooldown_hours:
        detail = (
            f"{symbol} contract {contract} was closed {round(newest_contract_hours, 2)} hours ago. "
            "Fresh catalyst required before re-entry."
        )
        return {
            "blocked": True,
            "reason": "recently_closed_same_contract",
            "detail": detail,
            "symbol": symbol,
            "contract": contract,
            "hours_since_close": round(newest_contract_hours, 4),
            "matched_trade_id": _safe_str(newest_contract_row.get("trade_id"), ""),
        }

    if newest_symbol_row and newest_symbol_hours <= symbol_cooldown_hours:
        detail = (
            f"{symbol} was closed {round(newest_symbol_hours, 2)} hours ago. "
            "Fresh catalyst required before re-entry."
        )
        return {
            "blocked": True,
            "reason": "recently_closed_symbol",
            "detail": detail,
            "symbol": symbol,
            "contract": contract,
            "hours_since_close": round(newest_symbol_hours, 4),
            "matched_trade_id": _safe_str(newest_symbol_row.get("trade_id"), ""),
        }

    return {
        "blocked": False,
        "reason": "no_recent_close_block",
        "symbol": symbol,
        "contract": contract,
    }


def _call_trade_cooldown_guard(selected_trades: List[Dict[str, Any]]) -> Dict[str, Any]:
    selected_trades = [
        _normalize_option_contract_identity(t)
        for t in selected_trades
        if isinstance(t, dict)
    ]

    fallback = {
        "input_count": len(selected_trades),
        "allowed_count": len(selected_trades),
        "blocked_count": 0,
        "queue": selected_trades,
        "allowed": selected_trades,
        "blocked": [],
        "allowed_symbols": [_norm_symbol(t.get("symbol")) for t in selected_trades],
        "blocked_symbols": [],
    }

    if not callable(guard_execution_queue):
        fallback["reason"] = "trade_cooldown_guard_unavailable"
        return fallback

    try:
        result = guard_execution_queue(
            selected_trades,
            symbol_cooldown_hours=48,
            contract_cooldown_hours=96,
            rejection_cooldown_hours=24,
            stale_setup_lookback_hours=36,
            stale_setup_max_appearances=4,
        )
    except TypeError:
        try:
            result = guard_execution_queue(selected_trades)
        except Exception as exc:
            fallback["reason"] = f"trade_cooldown_guard_exception:{exc}"
            return fallback
    except Exception as exc:
        fallback["reason"] = f"trade_cooldown_guard_exception:{exc}"
        return fallback

    if not isinstance(result, dict):
        fallback["reason"] = "trade_cooldown_guard_returned_non_dict"
        return fallback

    allowed = result.get("queue", result.get("allowed", []))
    if not isinstance(allowed, list):
        allowed = []

    blocked = result.get("blocked", [])
    if not isinstance(blocked, list):
        blocked = []

    allowed = [
        _normalize_option_contract_identity(t)
        for t in allowed
        if isinstance(t, dict)
    ]

    result["queue"] = allowed
    result["allowed"] = allowed
    result["blocked"] = [x for x in blocked if isinstance(x, dict)]
    result["input_count"] = _safe_int(result.get("input_count", len(selected_trades)), len(selected_trades))
    result["allowed_count"] = _safe_int(result.get("allowed_count", len(allowed)), len(allowed))
    result["blocked_count"] = _safe_int(result.get("blocked_count", len(result["blocked"])), len(result["blocked"]))
    result["allowed_symbols"] = [_norm_symbol(t.get("symbol")) for t in allowed]
    result["blocked_symbols"] = [
        _norm_symbol(t.get("symbol"))
        for t in result["blocked"]
        if isinstance(t, dict)
    ]

    return result


def _apply_strict_recent_close_guard(
    selected_trades: List[Dict[str, Any]],
    anti_repeat_selection_guard: Dict[str, Any],
) -> Tuple[List[Dict[str, Any]], Dict[str, Any]]:
    selected_trades = [
        _normalize_option_contract_identity(t)
        for t in selected_trades
        if isinstance(t, dict)
    ]

    anti_repeat_selection_guard = _safe_dict(anti_repeat_selection_guard)
    existing_blocked = [
        dict(x)
        for x in _safe_list(anti_repeat_selection_guard.get("blocked", []))
        if isinstance(x, dict)
    ]

    blocked: List[Dict[str, Any]] = list(existing_blocked)
    allowed: List[Dict[str, Any]] = []
    newly_blocked: List[Dict[str, Any]] = []

    already_blocked_symbols = {
        _norm_symbol(item.get("symbol", ""))
        for item in blocked
        if isinstance(item, dict)
    }

    for trade in selected_trades:
        symbol = _norm_symbol(trade.get("symbol"))

        if symbol in already_blocked_symbols:
            continue

        block = _recent_close_block_for_trade(trade)

        if block.get("blocked"):
            blocked_trade = dict(trade)
            reason = _safe_str(block.get("reason"), "recent_close_guard")
            detail = _safe_str(block.get("detail"), "Fresh catalyst required before re-entry.")

            blocked_trade["blocked_at"] = "anti_repeat_guard"
            blocked_trade["cooldown_reason"] = reason
            blocked_trade["cooldown_detail"] = detail
            blocked_trade["final_reason"] = reason
            blocked_trade["final_reason_code"] = reason
            blocked_trade["final_reason_detail"] = detail
            blocked_trade["execution_ready"] = False
            blocked_trade["selected_for_execution"] = False
            blocked_trade["recent_close_guard"] = block

            blocked.append(blocked_trade)
            newly_blocked.append(blocked_trade)
            already_blocked_symbols.add(symbol)
        else:
            allowed.append(trade)

    anti_repeat_selection_guard["queue"] = allowed
    anti_repeat_selection_guard["allowed"] = allowed
    anti_repeat_selection_guard["blocked"] = blocked
    anti_repeat_selection_guard["input_count"] = _safe_int(
        anti_repeat_selection_guard.get("input_count", len(selected_trades)),
        len(selected_trades),
    )
    anti_repeat_selection_guard["allowed_count"] = len(allowed)
    anti_repeat_selection_guard["blocked_count"] = len(blocked)
    anti_repeat_selection_guard["allowed_symbols"] = [
        _norm_symbol(t.get("symbol", ""))
        for t in allowed
        if isinstance(t, dict)
    ]
    anti_repeat_selection_guard["blocked_symbols"] = [
        _norm_symbol(t.get("symbol", ""))
        for t in blocked
        if isinstance(t, dict)
    ]

    if newly_blocked:
        print("PROCESS SIGNALS STRICT RECENT-CLOSE FILTER:", {
            "newly_blocked": [
                {
                    "symbol": item.get("symbol"),
                    "reason": item.get("cooldown_reason"),
                    "detail": item.get("cooldown_detail"),
                    "contract": item.get("contract_symbol"),
                }
                for item in newly_blocked
            ],
            "allowed_symbols_after_strict_filter": anti_repeat_selection_guard.get("allowed_symbols"),
            "blocked_symbols_after_strict_filter": anti_repeat_selection_guard.get("blocked_symbols"),
        })

    return allowed, anti_repeat_selection_guard


